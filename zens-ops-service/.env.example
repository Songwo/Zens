# Safe defaults: no write request leaves the runner until explicitly disabled.
OPS_ENVIRONMENT=production
OPS_DRY_RUN=true
OPS_DRAFT_ONLY=true
OPS_SERVICE_ID=zens-ops
OPS_SERVICE_SECRET=replace-with-a-long-random-secret
OPS_MAIN_SITE_BASE_URL=http://127.0.0.1:7800
OPS_AGENT_BASE_URL=http://127.0.0.1:7810
OPS_TIMEZONE=Asia/Shanghai
OPS_HTTP_TIMEOUT_SECONDS=10
OPS_HTTP_RETRIES=3
OPS_MAX_POSTS_PER_DAY=1
OPS_MAX_REPLIES_PER_DAY=10
OPS_FIRST_APPROVAL_POSTS=30
OPS_DEFAULT_SECTION_ID=1
OPS_KILL_SWITCH=false
OPS_SENSITIVE_TOPICS=politics,medical,legal,finance,minors,complaint,commercial,advertising,giveaway,paid,政治,医疗,法律,金融,未成年人,投诉,纠纷,商业承诺,广告,抽奖,付费

# Optional OpenAI-compatible writer. Template fallback is used when blank.
OPS_LLM_BASE_URL=
OPS_LLM_API_KEY=
OPS_LLM_MODEL=

# Health API binds loopback by default.
OPS_HEALTH_HOST=127.0.0.1
OPS_HEALTH_PORT=7820
OPS_LOG_LEVEL=INFO
