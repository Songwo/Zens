AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=7810
AGENT_LOG_LEVEL=INFO

# 搜索后端：auto / mysql / postgres
AGENT_SEARCH_BACKEND=auto

# PostgreSQL 只读搜索副本 / 搜索库（未来可切）
AGENT_POSTGRES_DSN=
AGENT_POSTGRES_MIN_POOL_SIZE=1
AGENT_POSTGRES_MAX_POOL_SIZE=10
AGENT_POSTGRES_CONNECT_TIMEOUT_SECONDS=5

# MySQL 只读副本。生产环境请使用仅有 SELECT / SHOW VIEW 权限的独立账号。
AGENT_MYSQL_REPLICA_DSN=jdbc:mysql://127.0.0.1:3308/campus_pulse?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
AGENT_MYSQL_REPLICA_USERNAME=agent_reader
AGENT_MYSQL_REPLICA_PASSWORD=change-me
AGENT_MYSQL_CONNECT_TIMEOUT_SECONDS=5
# true 时目标库必须同时开启 read_only 与 super_read_only，否则服务会拒绝启动。
AGENT_MYSQL_REQUIRE_READ_ONLY=true

# 问答检索
AGENT_DEFAULT_SEARCH_LIMIT=6
AGENT_MAX_SEARCH_LIMIT=12
AGENT_DEFAULT_COMMENTS_PER_POST=2
AGENT_MAX_COMMENTS_PER_POST=4
AGENT_MIN_QUESTION_LENGTH=2

# 可选：OpenAI 兼容大模型接口
AGENT_LLM_ENABLED=false
AGENT_LLM_BASE_URL=https://muyuan.do/v1
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-5.4
AGENT_LLM_TIMEOUT_SECONDS=18
AGENT_LLM_TEMPERATURE=0.1

# CORS
AGENT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://allinsong.top,https://www.allinsong.top
