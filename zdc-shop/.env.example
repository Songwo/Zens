# =============================================================================
# Zens 积分商城子站 - 环境变量示例
# 复制为 .env.local 并填入真实值。生产环境用 .env.production。
# =============================================================================

# ─── 数据库 ───────────────────────────────────────────────────────────────────
# 与主站同实例,单独建一个 zens_shop 库
DATABASE_URL="mysql://root:CHANGE_ME@localhost:3306/zens_shop"

# ─── 与主站共享的 JWT 密钥 (必须完全一致) ──────────────────────────────────────
# 用于验证 /sso/authorize 颁发的 ssoToken
JWT_SECRET="REPLACE_WITH_MAIN_SITE_JWT_SECRET_AT_LEAST_64_CHARS"

# ─── 主站内部 API HMAC 共享密钥 (与主站 SHOP_SERVICE_SECRET 完全一致) ──────────
# 用于子站调主站 /api/internal/user/*/points 的请求签名
SHOP_SERVICE_SECRET="REPLACE_WITH_SHOP_SERVICE_SECRET_AT_LEAST_32_CHARS"
SHOP_SERVICE_ID="zdc-shop"

# ─── 主站地址 ─────────────────────────────────────────────────────────────────
# 给子站后端调用主站内部 API
MAIN_SITE_BACKEND_URL="http://localhost:7800"
# 给子站前端跳转主站 SSO 授权页
NEXT_PUBLIC_COMMUNITY_URL="http://localhost:5173"
NEXT_PUBLIC_SSO_CLIENT_ID="zdc-shop"

# ─── iron-session 会话 ────────────────────────────────────────────────────────
# 必须 >= 32 字符的随机串,用于加密 cookie
SESSION_PASSWORD="REPLACE_WITH_RANDOM_32_OR_MORE_CHAR_STRING_FOR_COOKIE"
SESSION_COOKIE_NAME="zs_session"

# ─── 站点元信息 ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Zens · 积分商城"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Cloudflare R2 (图片对象存储,S3 兼容) ────────────────────────────────────
# R2 dashboard → R2 → 选 bucket → Settings 拿到 Account ID
R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2 dashboard → Manage R2 API Tokens → 创建 token,选 Object Read & Write
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# bucket 名,如 zdc-shop-assets
R2_BUCKET="zdc-shop-assets"
# 已绑定到 bucket 的自定义域名,结尾不要带 /
# 在 Cloudflare → R2 → 你的 bucket → Settings → Public Access → Custom Domains 绑定
R2_PUBLIC_BASE_URL="https://cdn.zens.community"
