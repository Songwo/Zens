MEDIA_SERVER_PORT=8090
MEDIA_PUBLIC_BASE_URL=http://localhost:8090
MEDIA_DATABASE_DSN=./data/media.db
MEDIA_STORAGE_ROOT_DIR=./uploads
MEDIA_STORAGE_TEMP_DIR=./tmp

MEDIA_UPLOAD_ENABLED=true
MEDIA_UPLOAD_MAX_BATCH_FILES=12
MEDIA_UPLOAD_MAX_IMAGE_MB=15
MEDIA_UPLOAD_MAX_VIDEO_MB=512
MEDIA_UPLOAD_CHUNK_SIZE_MB=8
MEDIA_UPLOAD_MAX_CONCURRENCY=64
MEDIA_UPLOAD_MERGE_CONCURRENCY=2

MEDIA_UPLOAD_AUTH_ENABLED=true
MEDIA_UPLOAD_JWT_SECRET=REPLACE_WITH_RANDOM_UPLOAD_JWT_SECRET_AT_LEAST_32_CHARS

MEDIA_ADMIN_USERNAME=admin
MEDIA_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_ADMIN_PASSWORD_AT_LEAST_16_CHARS
MEDIA_ADMIN_JWT_SECRET=REPLACE_WITH_RANDOM_ADMIN_JWT_SECRET_AT_LEAST_32_CHARS
MEDIA_ADMIN_SERVICE_TOKENS=REPLACE_WITH_RANDOM_SERVICE_TOKEN_AT_LEAST_32_CHARS

MEDIA_PER_IP_RPS=20
MEDIA_PER_USER_RPS=15
MEDIA_PUBLIC_FILE_ACCESS=true
