# Local Docker demonstration only. Copy this file to .env and replace every
# placeholder before running either bootstrap script. Never commit .env.
MYSQL_SOURCE_ROOT_PASSWORD=replace-with-a-strong-source-root-password
MYSQL_REPLICA_ROOT_PASSWORD=replace-with-a-strong-replica-root-password
MYSQL_REPLICATION_USER=replace_with_replication_user
MYSQL_REPLICATION_PASSWORD=replace-with-a-strong-replication-password

# The demo ports bind to 127.0.0.1 only.
MYSQL_SOURCE_PORT=3307
MYSQL_REPLICA_PORT=3308
