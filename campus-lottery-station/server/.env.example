# =============================================================================
# Zens 抽奖站 (campus-lottery-station) - 环境变量示例
# 复制为 .env.local 使用(本项目走 os.Getenv 直读,可用 direnv/dotenv 工具加载)。
# 详见 docs/ecosystem-config.md(生态统一配置命名对照表)。
# =============================================================================

# ─── 本站基础 ─────────────────────────────────────────────────────────────────
LOTTERY_ADDR=:8093
LOTTERY_PUBLIC_URL=http://localhost:8093
LOTTERY_DATA=data/state.json
LOTTERY_SESSION_SECRET=REPLACE_WITH_RANDOM_SESSION_SECRET

# ─── 主站连接(生态统一命名,旧名 COMMUNITY_BASE_URL/COMMUNITY_API_BASE_URL 长期兼容) ──
# 主站前端地址(SSO 跳转)
MAIN_SITE_WEB_URL=https://allinsong.top
# 主站后端地址(读帖子/评论、内部 s2s API)
MAIN_SITE_API_URL=https://api.allinsong.top
# 与主站共享的 JWT 密钥(必须完全一致),用于验证 SSO Token
MAIN_SITE_JWT_SECRET=REPLACE_WITH_MAIN_SITE_JWT_SECRET

# ─── SSO 客户端 ───────────────────────────────────────────────────────────────
SSO_CLIENT_ID=campus-lottery-station
SSO_CLIENT_SECRET=change-me

# ─── 本站服务身份(HMAC 内部 API,与主站 internal.service.clients 对应项完全一致) ──
# 参与付费抽奖时用于真实扣减主站积分;留空则付费抽奖直接拒绝参与(绝不本地假扣)
LOTTERY_SERVICE_ID=campus-lottery-station
LOTTERY_SERVICE_SECRET=REPLACE_WITH_LOTTERY_SERVICE_SECRET_AT_LEAST_16_CHARS

# ─── 机器人账号(评论回写/关帖) ─────────────────────────────────────────────────
LOTTERY_BOT_USERNAME=zens-lottery-bot
LOTTERY_BOT_ACCESS_TOKEN=
LOTTERY_BOT_PASSWORD=

# ─── 其他 ─────────────────────────────────────────────────────────────────────
LOTTERY_ALLOW_DEMO_SSO_FALLBACK=false
LOTTERY_COMMENT_MAX_PAGES=50
