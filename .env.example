# Song：本地开发运行配置示例（复制为 .env.local 使用）
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=7800

# Song：数据库
# Song：本地开发如果你的 MySQL 密码是 123456，可直接填写 123456
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_pulse?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=123456

# Song：Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0

# Song：邮件
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=REPLACE_WITH_MAIL_AUTH_CODE
MANAGEMENT_HEALTH_MAIL_ENABLED=true

# Song：JWT（必须替换）
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRE=7200000
JWT_REFRESH_EXPIRE=1209600000

# Song：跨域与请求签名
ALLOWED_ORIGIN_PATTERNS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Song：本地开发默认 false；生产环境建议 true。前端已支持 token 刷新后的自动重签名
REQUEST_SIGNATURE_REQUIRED=false
AUTH_SESSION_SINGLE_DEVICE=false
AUTH_SESSION_ANOMALY_NOTIFY_COOLDOWN_SECONDS=3600

# Song：内部 s2s API 白名单(Zens 子站调 /api/internal/**,详见 docs/ecosystem-config.md)
SHOP_SERVICE_SECRET=REPLACE_WITH_SHOP_SERVICE_SECRET_AT_LEAST_16_CHARS
LOTTERY_SERVICE_SECRET=REPLACE_WITH_LOTTERY_SERVICE_SECRET_AT_LEAST_16_CHARS
CDK_SERVICE_SECRET=REPLACE_WITH_CDK_SERVICE_SECRET_AT_LEAST_16_CHARS

# Song：静态资源地址
AVATAR_BASE_URL=http://localhost:7800/static/avatar/

# Song：AI
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat

# Song：GitHub 登录
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=http://localhost:5173/auth?type=login&provider=github

# Song：Cloudflare Turnstile
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY
TURNSTILE_ALLOW_LOCAL_PREVIEW_SKIP=false

# Song：二步验证
TWO_FACTOR_ISSUER=Zens社区
TWO_FACTOR_LOGIN_TICKET_EXPIRE_SECONDS=300
TWO_FACTOR_SETUP_EXPIRE_SECONDS=600

# Song：管理员联系入口
SUPPORT_ADMIN_USERNAME=admin
SUPPORT_ADMIN_DISPLAY_NAME=社区管理员

# Song：日志文件
LOG_FILE=./log/logfile.log
REQUEST_LOG_ENABLED=true
SLOW_REQUEST_MS=1000
SLOW_SQL_MS=300
REQUEST_LOG_EXCLUDE_PREFIXES=/actuator,/static,/uploads

# Song：上传与转码
MAX_IMAGE_SIZE_MB=5
MAX_IMAGE_WIDTH=1920
MAX_IMAGE_HEIGHT=1080
IMAGE_JPEG_QUALITY=0.85
MAX_VIDEO_SIZE_MB=80
ALLOWED_VIDEO_EXTENSIONS=.mp4,.webm,.ogg,.mov
VIDEO_TRANSCODE_ENABLED=true
FFMPEG_BIN=ffmpeg
VIDEO_TRANSCODE_CRF=28

# Song：Cloudflare R2（浏览器直传）
R2_ENABLED=true
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
R2_BUCKET=campus-pulse-media
R2_PUBLIC_BASE_URL=https://media.allinsong.top
R2_PRESIGN_TTL=3600
R2_SINGLE_PUT_THRESHOLD_MB=5
R2_PART_SIZE_MB=8
R2_MAX_IMAGE_MB=15
R2_MAX_VIDEO_MB=1024
R2_ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp
R2_ALLOWED_VIDEO_EXTENSIONS=.mp4,.webm,.ogg,.mov
R2_CACHE_CONTROL=public, max-age=3600, stale-while-revalidate=60
