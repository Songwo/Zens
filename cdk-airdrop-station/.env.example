HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_VERIFY_URL=https://api.hcaptcha.com/siteverify
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# PostgreSQL 配置。Docker Compose 会自动启动 postgres 服务。
POSTGRES_DB=cdk_airdrop
POSTGRES_USER=cdk_airdrop
POSTGRES_PASSWORD=cdk_airdrop_change_me
CDK_POSTGRES_DSN=postgres://cdk_airdrop:cdk_airdrop_change_me@postgres:5432/cdk_airdrop?sslmode=disable

# 兼容旧 MySQL 部署，默认不启用。设置 CDK_POSTGRES_DSN 后会优先使用 PostgreSQL。
CDK_MYSQL_DSN=

# 可选增强组件。默认留空，应用可直接使用 PostgreSQL 运行。
# 如需启用：docker compose --profile cache up -d --build
CDK_AIRDROP_REDIS_URL=
CDK_AIRDROP_RABBITMQ_URL=

# 社区 SSO 配置
CDK_COMMUNITY_URL=http://localhost:5173
CDK_COMMUNITY_CLIENT_ID=cdk-airdrop
CDK_COMMUNITY_JWT_SECRET=your_jwt_secret_here
