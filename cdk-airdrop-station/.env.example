# Zens CDK 空投站 Docker 部署配置
# 复制为 .env 后修改。生产环境不要使用示例密钥。

# 对外访问地址。宝塔/Nginx 反代时建议只绑定 127.0.0.1。
CDK_AIRDROP_BIND=127.0.0.1
CDK_AIRDROP_PORT=8088
CDK_PUBLIC_URL=https://cdk.allinsong.top

# hCaptcha。测试 key 只适合本地开发；生产请替换成你自己的站点 key/secret。
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_VERIFY_URL=https://api.hcaptcha.com/siteverify
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# PostgreSQL 配置。Docker Compose 会自动启动 postgres 服务。
POSTGRES_DB=cdk_airdrop
POSTGRES_USER=cdk_airdrop
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
CDK_POSTGRES_DSN=postgres://cdk_airdrop:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/cdk_airdrop?sslmode=disable

# 兼容旧 MySQL 部署，默认不启用。设置 CDK_POSTGRES_DSN 后会优先使用 PostgreSQL。
CDK_MYSQL_DSN=

# 可选增强组件。默认留空，应用可直接使用 PostgreSQL 运行。
# 如需启用：docker compose --profile cache up -d --build
CDK_AIRDROP_REDIS_URL=
CDK_AIRDROP_RABBITMQ_URL=

# 社区 SSO 配置(生态统一命名,详见 docs/ecosystem-config.md)
# 主站前端地址,用于 SSO 跳转。生产示例: https://allinsong.top
MAIN_SITE_WEB_URL=https://allinsong.top
CDK_COMMUNITY_CLIENT_ID=cdk-airdrop
# 与主站共享的 JWT 密钥(必须完全一致),用于验证 SSO Token
MAIN_SITE_JWT_SECRET=REPLACE_WITH_MAIN_SITE_JWT_SECRET

# 主站内部 s2s API(事件回流:领取成功写主站账本 + 站内通知)
# 主站后端地址,用于调用 /api/internal/subsite/events
MAIN_SITE_API_URL=https://api.allinsong.top
# 本站服务身份(HMAC),与主站 internal.service.clients 里 id=cdk-airdrop 的密钥完全一致
# 留空则跳过事件回流(领取功能本身不受影响,只是不通知主站)
CDK_SERVICE_ID=cdk-airdrop
CDK_SERVICE_SECRET=REPLACE_WITH_CDK_SERVICE_SECRET_AT_LEAST_16_CHARS

# 常用安全响应头。默认开启 CSP/HSTS；如本地调试 iframe/captcha 异常可临时放宽。
CDK_AIRDROP_CSP_ENABLED=true
CDK_AIRDROP_HSTS_ENABLED=true
